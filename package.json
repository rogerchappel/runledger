{
  "name": "runledger",
  "version": "0.1.0",
  "description": "Local-first tamper-evident command run ledger for developers and agents.",
  "type": "module",
  "bin": {
    "runledger": "./dist/src/index.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "docs",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "prepack": "npm run build",
    "package:smoke": "npm run build && test -f dist/src/index.js && test -f dist/src/index.d.ts && test -f examples/sample-runs.jsonl && npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "ledger",
    "jsonl",
    "tamper-evident",
    "local-first",
    "agent-tools"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/runledger.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/runledger/issues"
  },
  "homepage": "https://github.com/rogerchappel/runledger#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
